        "selector": [
          "reflex",
          "fortitude"
        ],
        "value": "ternary(gte(@actor.level, 15), 6, ternary(gte(@actor.level, 10), 4, 2))",
        "label": "Turret Saves Proficiency",
        "type": "proficiency"
      }
    ],
